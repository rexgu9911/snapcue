{
  "name": "snapcue",
  "version": "0.1.3",
  "description": "macOS menu bar AI study assistant",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "pack": "electron-vite build && electron-builder --mac --config && mkdir -p dist && cp /tmp/snapcue-dist/SnapCue-*.dmg dist/",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint . --ext .ts,.tsx && prettier --check .",
    "lint:fix": "eslint . --ext .ts,.tsx --fix && prettier --write .",
    "typecheck": "tsc --noEmit"
  },
  "author": "",
  "license": "UNLICENSED",
  "private": true,
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.4",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/sharp": "^0.31.1",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "electron": "^30.0.0",
    "electron-builder": "^24.13.0",
    "electron-vite": "^2.3.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.34.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "prettier": "^3.3.0",
    "tailwindcss": "^4.1.4",
    "typescript": "^5.5.0",
    "vite": "^5.3.0",
    "vitest": "^1.6.0"
  },
  "build": {
    "appId": "com.snapcue.app",
    "productName": "SnapCue",
    "publish": {
      "provider": "github",
      "owner": "rexgu9911",
      "repo": "snapcue"
    },
    "directories": {
      "output": "/tmp/snapcue-dist"
    },
    "files": [
      "out/**/*",
      "resources/**/*"
    ],
    "asarUnpack": [
      "node_modules/sharp/**/*",
      "node_modules/@img/**/*"
    ],
    "protocols": [
      {
        "name": "SnapCue",
        "schemes": [
          "snapcue"
        ]
      }
    ],
    "extraMetadata": {
      "main": "out/main/index.js"
    },
    "afterSign": "scripts/notarize.js",
    "afterAllArtifactBuild": "scripts/notarize-dmg.js",
    "mac": {
      "target": "dmg",
      "category": "public.app-category.education",
      "icon": "build/icon.icns",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "notarize": false
    },
    "dmg": {
      "background": "build/dmg-background.png",
      "window": {
        "width": 540,
        "height": 380
      },
      "iconSize": 100,
      "iconTextSize": 12,
      "contents": [
        {
          "x": 140,
          "y": 200
        },
        {
          "x": 400,
          "y": 200,
          "type": "link",
          "path": "/Applications"
        }
      ]
    }
  },
  "dependencies": {
    "@electron-toolkit/utils": "^4.0.0",
    "@supabase/supabase-js": "^2.104.0",
    "electron-updater": "^6.8.3",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "sharp": "^0.34.5"
  }
}
