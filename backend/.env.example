OPENAI_API_KEY=sk-your-openai-api-key-here
PORT=3001
SNAPCUE_API_KEY=dev-test-key-change-me

# Supabase — required since Phase 6.2. Service-role key, server-only, never
# ship to the client. Grab from Supabase dashboard → Project Settings → API.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stripe — required since Phase 6.3. Use test mode keys for dev, live keys
# for prod. SECRET_KEY is server-only. WEBHOOK_SECRET is filled after
# registering the webhook endpoint in Dashboard. Price IDs are created via
# Stripe Dashboard → Catalog → Add product (one Price per Product).
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_WEEKLY=price_xxx
STRIPE_PRICE_MONTHLY=price_xxx
STRIPE_PRICE_PACK_30=price_xxx
STRIPE_PRICE_PACK_100=price_xxx
