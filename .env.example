# Copy to `.env.development` (npm run dev) or `.env.production` (npm run pack)
# and fill in real values. Both files are gitignored.
#
# All vars are prefixed SNAPCUE_ because Vite's envPrefix limits which env
# vars get bundled into the renderer at build time.

# Backend API the Electron main process talks to.
#   Dev:  http://localhost:3001 (Fastify in ./backend)
#   Prod: https://snapcue-production.up.railway.app
SNAPCUE_API_URL=https://your-api-url.com

# Anti-abuse key required by backend onRequest hook. Must match the
# SNAPCUE_API_KEY value in backend/.env. Leave blank in dev for the
# no-key fallback in server.ts.
SNAPCUE_API_KEY=your-api-key

# Supabase project — auth-only (Magic Link). Use the *anon/publishable*
# key (sb_publishable_...), NOT the service_role secret.
SNAPCUE_SUPABASE_URL=https://xxxxx.supabase.co
SNAPCUE_SUPABASE_ANON_KEY=sb_publishable_xxxxx

# Marketing / pricing site URL. The Electron app opens this in the user's
# browser when they click "Get more credits" or "Manage subscription".
#   Dev:  http://localhost:3000
#   Prod: https://snapcue.io
SNAPCUE_WEB_URL=https://snapcue.io
